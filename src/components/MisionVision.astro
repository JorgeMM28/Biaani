---
---

<section id="mision" class="mv-section">
  <!-- Decorative quote mark -->
  <div class="mv-section__deco" aria-hidden="true">"</div>

  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Nosotros · Biaani</span>
      <h2>Lo que nos <span class="gradient-text">inspira</span></h2>
    </div>

    <div class="mv-cards">
      <!-- Misión -->
      <div class="mv-card mv-card--mision animate-on-scroll">
        <div class="mv-card__icon-wrap">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="10 8 16 12 10 16 10 8"/>
          </svg>
        </div>
        <span class="mv-card__label">Misión</span>
        <h3>Iluminar cada espacio que habitas</h3>
        <p>
          Queremos que cada vela ilumine tus espacios, te haga sentir especial y transforme cualquier
          ambiente en algo único, combinando calidad, creatividad y materiales sostenibles para crear
          una experiencia acogedora y relajante.
        </p>
        <div class="mv-card__deco-line"></div>
      </div>

      <!-- Visión -->
      <div class="mv-card mv-card--vision animate-on-scroll" style="animation-delay:0.15s">
        <div class="mv-card__icon-wrap">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <span class="mv-card__label">Visión</span>
        <h3>Una marca que acompaña tu vida</h3>
        <p>
          Ser una empresa eficaz y dinámica que acompañe la vida diaria de las personas transformando
          espacios que despierten emociones, recuerdos y sensaciones únicas, logrando ser una marca
          confiable, sostenible e innovadora.
        </p>
        <div class="mv-card__deco-line"></div>
      </div>
    </div>

    <!-- Values band -->
    <div class="values-band animate-on-scroll">
      <p class="values-band__title">Nuestros valores</p>
      <div class="values-list">
        {[
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, label: 'Calidad' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C8.5 8 3 10 3 16a9 9 0 0 0 18 0c0-6-5.5-8-9-14z"/></svg>`, label: 'Sostenibilidad' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-1.04-4.72A2.5 2.5 0 0 1 6.5 9.5a2.5 2.5 0 0 1 3-3.45V5.5A2.5 2.5 0 0 1 9.5 2zm4.5 0A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 1.04-4.72A2.5 2.5 0 0 0 17.5 9.5a2.5 2.5 0 0 0-3-3.45V5.5A2.5 2.5 0 0 0 14 2z"/></svg>`, label: 'Creatividad' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`, label: 'Bienestar' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, label: 'Cercanía' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`, label: 'Confianza' },
        ].map(v => (
          <div class="value-chip">
            <span class="value-chip__icon" set:html={v.icon} />
            <span>{v.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Brand story snippet -->
    <div class="brand-story animate-on-scroll">
      <div class="brand-story__visual">
        <img src="/logo.png" alt="Logo Biaani – Velas artesanales Erandi" />
      </div>
      <div class="brand-story__text">
        <span class="section-label">Erandi — Nuestra marca</span>
        <h3>Cada vela, una historia</h3>
        <p>
          Biaani nació de la pasión por transformar espacios y conectar personas con su bienestar.
          Fundada por <strong>Erandi</strong>, nuestra empresa lleva el alma artesana de México en cada
          fragancia, en cada llama, en cada momento de calma que regalamos.
        </p>
        <p>
          Creemos que el hogar merece ser un santuario. Que un aroma puede cambiar tu estado de ánimo.
          Que un regalo hecho a mano dice más que cualquier otro.
        </p>
        <a href="#contacto" class="btn-outline" style="margin-top:1.5rem">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Escríbenos
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .mv-section {
    padding: 6rem 0;
    background: linear-gradient(180deg,
      var(--off-white) 0%,
      var(--beige-50) 50%,
      var(--rose-50) 100%
    );
    position: relative;
    overflow: hidden;
  }

  .mv-section__deco {
    position: absolute;
    top: -2rem;
    left: 2%;
    font-family: var(--font-serif);
    font-size: 25rem;
    line-height: 1;
    color: var(--rose-100);
    pointer-events: none;
    user-select: none;
    opacity: 0.5;
    z-index: 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  .section-header h2 { margin-bottom: 0.5rem; }

  /* Mission/Vision cards */
  .mv-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  .mv-card {
    background: var(--white);
    border: 1.5px solid var(--beige-100);
    border-radius: var(--radius-xl);
    padding: 2.5rem 2rem;
    position: relative;
    overflow: hidden;
    transition: var(--transition);
  }

  .mv-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-hover);
  }

  .mv-card--mision {
    border-top: 3px solid var(--rose-300);
  }

  .mv-card--vision {
    border-top: 3px solid var(--gold-400);
  }

  .mv-card__icon-wrap {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .mv-card--mision .mv-card__icon-wrap {
    background: linear-gradient(135deg, var(--rose-50), var(--rose-100));
    color: var(--rose-400);
  }

  .mv-card--vision .mv-card__icon-wrap {
    background: linear-gradient(135deg, var(--beige-50), var(--beige-200));
    color: var(--gold-500);
  }

  .mv-card__label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-500);
    margin-bottom: 0.6rem;
  }

  .mv-card h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .mv-card p {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  .mv-card__deco-line {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.4s;
  }

  .mv-card--mision .mv-card__deco-line {
    background: linear-gradient(90deg, var(--rose-200), var(--rose-400), var(--rose-200));
  }

  .mv-card--vision .mv-card__deco-line {
    background: linear-gradient(90deg, var(--beige-200), var(--gold-400), var(--beige-200));
  }

  .mv-card:hover .mv-card__deco-line { opacity: 1; }

  /* Values */
  .values-band {
    background: var(--white);
    border: 1px solid var(--beige-200);
    border-radius: var(--radius-xl);
    padding: 2rem 2.5rem;
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  .values-band__title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-500);
    margin-bottom: 1.25rem;
  }

  .values-list {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .value-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, var(--rose-50), var(--beige-50));
    border: 1px solid var(--beige-200);
    border-radius: var(--radius-full);
    padding: 0.55rem 1.1rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: var(--transition);
  }

  .value-chip:hover {
    border-color: var(--rose-300);
    color: var(--text-primary);
    transform: translateY(-2px);
  }

  .value-chip__icon {
    color: var(--rose-400);
    display: flex;
  }

  /* Brand story */
  .brand-story {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: center;
    background: linear-gradient(135deg, var(--beige-50), var(--rose-50));
    border: 1.5px solid var(--beige-200);
    border-radius: var(--radius-xl);
    padding: 3rem;
    position: relative;
    z-index: 1;
  }

  .brand-story__visual {
    width: 180px;
    flex-shrink: 0;
  }

  .brand-story__visual img {
    width: 180px;
    height: 180px;
    object-fit: contain;
    border-radius: var(--radius-lg);
    filter: drop-shadow(0 8px 24px rgba(180,110,80,0.18));
    /* Fondo blanco del PNG desaparece contra el fondo claro */
    mix-blend-mode: multiply;
    transition: transform 0.5s ease;
  }

  .brand-story__visual img:hover {
    transform: rotate(-3deg) scale(1.04);
  }

  .brand-story__text h3 {
    font-size: 1.6rem;
    margin: 0.5rem 0 1rem;
  }

  .brand-story__text p {
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .brand-story__text strong {
    color: var(--gold-500);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .mv-cards { grid-template-columns: 1fr; }
    .brand-story { grid-template-columns: 1fr; text-align: center; padding: 2rem; }
    .brand-story__visual { margin-inline: auto; }
    .values-band { padding: 1.5rem; }
  }

  @media (max-width: 480px) {
    .mv-section { padding: 4rem 0; }
    .mv-card { padding: 1.75rem 1.25rem; }
    .brand-story { padding: 1.5rem; }
    .brand-story__visual img { width: 130px; height: 130px; }
  }
</style>
