---
---

<!-- =============================================
     PRODUCT SECTION — Gallery Carousel
============================================= -->
<section id="producto" class="product-section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Nuestro Producto</span>
      <h2>Velas que <em>cuentan</em> historias</h2>
      <p class="section-desc">
        Cada pieza es elaborada a mano con dedicación. Las velas Biaani combinan estética,
        aroma y bienestar en un solo objeto de diseño.
      </p>
    </div>

    <!-- Price highlight -->
    <div class="product-price-highlight animate-on-scroll">
      <div class="pph__inner">
        <div class="pph__text">
          <h3>Biaani Vela Aromática</h3>
          <p>Disponible en múltiples aromas y presentaciones. Cada vela es única.</p>
          <ul class="pph__features">
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              Cera de soya 100% natural
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              Pabilo de algodón
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              Envase de vidrio reutilizable
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              Personalizable con fragancia
            </li>
          </ul>
        </div>
        <div class="pph__price-box">
          <span class="pph__currency">$</span>
          <span class="pph__amount">150</span>
          <span class="pph__denom">MXN</span>
          <p class="pph__note">por vela</p>
          <a href="#contacto" class="btn-primary" style="margin-top:1.25rem; width:100%; justify-content:center;">
            Pedir ahora
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Product gallery carousel -->
    <div class="gallery-carousel animate-on-scroll" id="gallery-carousel">
      <div class="gallery-carousel__track" id="gallery-track">
        <!-- Slide 1: 3 velas main -->
        <div class="gallery-slide">
          <div class="gallery-slide__img-wrap">
            <img src="/3velas.png" alt="Velas artesanales Biaani – colección principal" loading="lazy" />
          </div>
          <div class="gallery-slide__caption">
            <span class="gallery-slide__tag">Producto estrella</span>
            <p>Colección de velas en vidrio con diseño artesanal y fragancias naturales. Pink Peony &amp; Jasmine, Zen Lotus &amp; Amber, y kit premium envuelto a mano.</p>
          </div>
        </div>

        <!-- Slide 2: mini velas kit -->
        <div class="gallery-slide">
          <div class="gallery-slide__img-wrap">
            <img src="/productos.png" alt="Mini velas Biaani – kit de aromas" loading="lazy" />
          </div>
          <div class="gallery-slide__caption">
            <span class="gallery-slide__tag">Mini Kit</span>
            <p>Descubre nuestros aromas antes de elegir tu favorito: Vainilla y Coco, Lavanda, Rosas, Sándalo, Brisa Cítrica y Flor de Algodón.</p>
          </div>
        </div>

        <!-- Slide 3: spray perfume -->
        <div class="gallery-slide">
          <div class="gallery-slide__img-wrap">
            <img src="/promo/spray_perfume.png" alt="Spray aromático de autor Biaani" loading="lazy" />
          </div>
          <div class="gallery-slide__caption">
            <span class="gallery-slide__tag">Perfumes de autor</span>
            <p>Spray aromático de autor Biaani — fragancia exclusiva para perfumar tu espacio y tu piel.</p>
          </div>
        </div>

        <!-- Slide 4: bolsa papel -->
        <div class="gallery-slide">
          <div class="gallery-slide__img-wrap">
            <img src="/promo/bolsa_papel.png" alt="Bolsa de regalo Biaani" loading="lazy" />
          </div>
          <div class="gallery-slide__caption">
            <span class="gallery-slide__tag">Empaque ecológico</span>
            <p>Empaque premium en papel con diseño Biaani — perfecto para regalar con estilo.</p>
          </div>
        </div>

        <!-- Slide 5: bolsita tela -->
        <div class="gallery-slide">
          <div class="gallery-slide__img-wrap">
            <img src="/promo/bolsita_tela.png" alt="Bolsita de tela artesanal Biaani" loading="lazy" />
          </div>
          <div class="gallery-slide__caption">
            <span class="gallery-slide__tag">Empaque artesanal</span>
            <p>Bolsita de tela con cordón rosa — presentación especial para regalo con sello Biaani.</p>
          </div>
        </div>

        <!-- Slide 6: tarjeta gracias -->
        <div class="gallery-slide">
          <div class="gallery-slide__img-wrap">
            <img src="/promo/tarjeta_gracias.png" alt="Tarjeta de agradecimiento Biaani" loading="lazy" />
          </div>
          <div class="gallery-slide__caption">
            <span class="gallery-slide__tag">Detalle especial</span>
            <p>Tarjeta de agradecimiento personalizada incluida en cada pedido. Por elegir fragancias que iluminan tu alma.</p>
          </div>
        </div>
      </div>

      <!-- Controls -->
      <button class="gallery-btn gallery-btn--prev" id="gallery-prev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="gallery-btn gallery-btn--next" id="gallery-next" aria-label="Siguiente">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>

      <!-- Dots -->
      <div class="gallery-dots" id="gallery-dots"></div>
    </div>
  </div>
</section>

<style>
  .product-section {
    padding: 6rem 0;
    background: linear-gradient(180deg, var(--off-white) 0%, var(--rose-50) 50%, var(--off-white) 100%);
    position: relative;
    overflow: hidden;
  }

  .product-section::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--rose-200), transparent);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-header h2 {
    margin-bottom: 1rem;
  }

  .section-header em {
    font-style: italic;
    color: var(--rose-400);
  }

  .section-desc {
    color: var(--text-secondary);
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* Price highlight card */
  .product-price-highlight {
    margin-bottom: 3rem;
  }

  .pph__inner {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--beige-200);
    padding: 2.5rem;
    box-shadow: var(--shadow-card);
  }

  .pph__text {
    flex: 1;
  }

  .pph__text h3 {
    font-size: 1.5rem;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
  }

  .pph__text > p {
    color: var(--text-secondary);
    margin-bottom: 1.2rem;
  }

  .pph__features {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem;
  }

  .pph__features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .pph__features li svg {
    color: var(--gold-500);
    flex-shrink: 0;
  }

  .pph__price-box {
    text-align: center;
    padding: 1.5rem 2rem;
    background: linear-gradient(145deg, var(--rose-50), var(--beige-50));
    border-radius: var(--radius-md);
    border: 1.5px solid var(--beige-200);
    min-width: 180px;
    flex-shrink: 0;
  }

  .pph__currency {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--gold-500);
    vertical-align: top;
    margin-top: 0.5rem;
    display: inline-block;
  }

  .pph__amount {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--gold-500);
    line-height: 1;
  }

  .pph__denom {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-light);
    display: block;
    letter-spacing: 0.08em;
  }

  .pph__note {
    font-size: 0.78rem;
    color: var(--text-xlight);
    margin-top: 0.25rem;
  }

  /* Gallery Carousel */
  .gallery-carousel {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    /* Prevent subpixel border bleeding between slides */
    isolation: isolate;
  }

  .gallery-carousel__track {
    display: flex;
    will-change: transform;
    /* transition mas fluida, rapida al inicio y suave al final (Premium easeOutExpo) */
    transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-slide {
    flex: 0 0 100%;
    min-width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 460px;
    background: var(--white);
    overflow: hidden;
  }

  .gallery-slide__img-wrap {
    overflow: hidden;
    position: relative;
    background: var(--beige-50);
  }

  .gallery-slide__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 2rem;
    /* Zoom suave al entrar y transicion de escala inicial */
    opacity: 0.6;
    transform: scale(0.94) translateZ(0);
    transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    /* Difuminado sutil en los bordes de la imagen */
    -webkit-mask-image: radial-gradient(circle at center, black 82%, rgba(0,0,0,0.35) 96%, transparent 100%);
    mask-image: radial-gradient(circle at center, black 82%, rgba(0,0,0,0.35) 96%, transparent 100%);
  }

  /* Animacion premium cuando la slide esta activa */
  .gallery-slide.active .gallery-slide__img-wrap img {
    opacity: 1;
    transform: scale(1) translateZ(0);
  }

  .gallery-slide.active:hover .gallery-slide__img-wrap img {
    transform: scale(1.05) translateZ(0);
  }

  .gallery-slide__caption {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem 3rem;
    background: linear-gradient(135deg, var(--white) 0%, var(--rose-50) 100%);
  }


  .gallery-slide__tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-500);
    background: linear-gradient(135deg, var(--beige-100), var(--rose-50));
    border: 1px solid var(--beige-200);
    border-radius: var(--radius-full);
    padding: 0.3rem 0.8rem;
    margin-bottom: 1rem;
    width: fit-content;
    /* Slide text entry */
    opacity: 0.3;
    transform: translateY(12px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.1s;
  }

  .gallery-slide.active .gallery-slide__tag {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery-slide__caption p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.65;
    /* Slide text entry */
    opacity: 0.3;
    transform: translateY(16px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.22s;
  }

  .gallery-slide.active .gallery-slide__caption p {
    opacity: 1;
    transform: translateY(0);
  }

  /* Nav buttons */
  .gallery-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255,255,255,0.92);
    border: 1.5px solid var(--beige-200);
    color: var(--gold-500);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
    backdrop-filter: blur(8px);
  }

  .gallery-btn:hover {
    background: var(--gold-400);
    color: var(--white);
    border-color: var(--gold-400);
    transform: translateY(-50%) scale(1.06);
  }

  .gallery-btn--prev { left: 1rem; }
  .gallery-btn--next { right: 1rem; }

  /* Dots */
  .gallery-dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    z-index: 5;
  }

  .gallery-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--beige-300);
    border: none;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    padding: 0;
  }

  .gallery-dot.active {
    background: var(--gold-400);
    transform: scale(1.35);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .pph__inner { flex-direction: column; }
    .pph__features { grid-template-columns: 1fr 1fr; }
    .pph__price-box { width: 100%; }
  }

  @media (max-width: 768px) {
    .gallery-slide {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .gallery-slide__img-wrap {
      height: 280px;
    }

    .gallery-slide__caption {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .product-section { padding: 4rem 0; }
    .pph__features { grid-template-columns: 1fr; }
    .pph__inner { padding: 1.5rem; }
    .gallery-slide__img-wrap { height: 220px; }
  }
</style>


<script>
  const track = document.getElementById('gallery-track')!;
  const dotsContainer = document.getElementById('gallery-dots')!;
  const prevBtn = document.getElementById('gallery-prev')!;
  const nextBtn = document.getElementById('gallery-next')!;
  const slides = track.querySelectorAll('.gallery-slide');
  let current = 0;
  const total = slides.length;

  // Build dots
  slides.forEach((_, i) => {
    const dot = document.createElement('button');
    dot.className = 'gallery-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', `Ir a imagen ${i + 1}`);
    dot.addEventListener('click', () => goTo(i));
    dotsContainer.appendChild(dot);
  });

  const dots = dotsContainer.querySelectorAll('.gallery-dot');

  function goTo(idx: number) {
    current = (idx + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
    slides.forEach((slide, i) => slide.classList.toggle('active', i === current));
  }

  // Set initial active state
  goTo(0);

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  // Auto-play
  let timer = setInterval(() => goTo(current + 1), 5000);

  const carousel = document.getElementById('gallery-carousel')!;
  carousel.addEventListener('mouseenter', () => clearInterval(timer));
  carousel.addEventListener('mouseleave', () => {
    timer = setInterval(() => goTo(current + 1), 5000);
  });

  // Touch/swipe support
  let startX = 0;
  carousel.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
  carousel.addEventListener('touchend', (e) => {
    const diff = startX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
  }, { passive: true });
</script>
