---
---

<section id="inicio" class="hero">
  <!-- Decorative background blobs -->
  <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--2" aria-hidden="true"></div>
  <div class="hero__blob hero__blob--3" aria-hidden="true"></div>

  <div class="container hero__inner">
    <!-- Text column -->
    <div class="hero__text">
      <span class="section-label">Velas Artesanales Biaani</span>

      <h1 class="hero__title">
        Ilumina tu espacio,<br/>
        <span class="gradient-text">transforma tu alma</span>
      </h1>

      <p class="hero__desc">
        Cada vela Biaani es una obra hecha a mano con materiales naturales,
        aromas únicos y acabados que transforman cualquier rincón en un refugio de calma.
      </p>

      <div class="hero__price-badge">
        <span class="hero__price-label">Desde</span>
        <span class="hero__price-amount">$150</span>
        <span class="hero__price-sub">MXN c/u</span>
      </div>

      <div class="hero__actions">
        <a href="#contacto" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Hacer pedido
        </a>
        <a href="#producto" class="btn-outline">
          Conocer más
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>

      <!-- Trust badges -->
      <div class="hero__badges">
        <div class="hero__badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span>Hecho a mano</span>
        </div>
        <div class="hero__badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="2"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/></svg>
          <span>Entrega rápida</span>
        </div>
        <div class="hero__badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="2"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/><polyline points="16 21 16 7 8 7 8 21"/></svg>
          <span>Materiales naturales</span>
        </div>
      </div>
    </div>

    <!-- Image column -->
    <div class="hero__visual">
      <div class="hero__image-wrapper">
        <div class="hero__ring hero__ring--outer" aria-hidden="true"></div>
        <div class="hero__ring hero__ring--inner" aria-hidden="true"></div>
        <img
          src="/3velas.png"
          alt="Velas artesanales Biaani - producto principal"
          class="hero__product-img"
          width="520"
          height="580"
        />
        <!-- Floating decoration chips -->
        <div class="hero__chip hero__chip--1">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--rose-400)" stroke-width="1.5"><path d="M12 2C8.5 8 3 10 3 16a9 9 0 0 0 18 0c0-6-5.5-8-9-14z"/></svg>
          <span>Soya 100%</span>
        </div>
        <div class="hero__chip hero__chip--2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--gold-500)" stroke-width="1.5"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <span>Aromas naturales</span>
        </div>
        <div class="hero__chip hero__chip--3">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--rose-400)" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span>Personalizable</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#producto" class="hero__scroll-hint" aria-label="Bajar">
    <span class="hero__scroll-line"></span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--gold-400)" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 80px;
    background-color: var(--rose-50);
    background-image: linear-gradient(160deg,
      var(--off-white) 0%,
      var(--rose-50) 40%,
      var(--beige-50) 70%,
      var(--off-white) 100%
    );
    background-attachment: scroll;
  }


  /* Background blobs */
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.5;
    pointer-events: none;
  }

  .hero__blob--1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, var(--rose-200) 0%, transparent 70%);
    top: -100px; right: -100px;
    animation: float 10s ease-in-out infinite;
  }

  .hero__blob--2 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, var(--beige-300) 0%, transparent 70%);
    bottom: 100px; left: -80px;
    animation: float 13s ease-in-out infinite reverse;
  }

  .hero__blob--3 {
    width: 200px; height: 200px;
    background: radial-gradient(circle, var(--gold-300) 0%, transparent 70%);
    top: 40%; left: 40%;
    opacity: 0.25;
    animation: float 8s ease-in-out infinite 2s;
  }

  /* Inner layout */
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
    padding-block: 3rem;
    width: 100%;
  }

  /* Text animations replaced by robust, ultra-smooth GPU transitions */
  .hero__title {
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.25rem;
    opacity: 0;
    transform: translateY(28px) translateZ(0);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero.is-loaded .hero__title {
    opacity: 1;
    transform: translateY(0) translateZ(0);
  }

  .hero__desc {
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 1.75rem;
    opacity: 0;
    transform: translateY(24px) translateZ(0);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.12s;
  }

  .hero.is-loaded .hero__desc {
    opacity: 1;
    transform: translateY(0) translateZ(0);
  }

  .hero__price-badge {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    background: linear-gradient(135deg, var(--beige-100), var(--rose-50));
    border: 1.5px solid var(--beige-300);
    border-radius: var(--radius-full);
    padding: 0.5rem 1.2rem;
    margin-bottom: 1.75rem;
    opacity: 0;
    transform: translateY(20px) translateZ(0);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.22s;
  }

  .hero.is-loaded .hero__price-badge {
    opacity: 1;
    transform: translateY(0) translateZ(0);
  }

  .hero__price-label {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-light);
    letter-spacing: 0.05em;
  }

  .hero__price-amount {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 500;
    color: var(--gold-500);
    line-height: 1;
  }

  .hero__price-sub {
    font-size: 0.78rem;
    color: var(--text-light);
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    opacity: 0;
    transform: translateY(20px) translateZ(0);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.28s;
  }

  .hero.is-loaded .hero__actions {
    opacity: 1;
    transform: translateY(0) translateZ(0);
  }

  .hero__badges {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(16px) translateZ(0);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.36s;
  }

  .hero.is-loaded .hero__badges {
    opacity: 1;
    transform: translateY(0) translateZ(0);
  }

  .hero__badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  /* Visual / product image */
  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.92) translateZ(0);
    transition: opacity 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.08s;
  }

  .hero.is-loaded .hero__visual {
    opacity: 1;
    transform: scale(1) translateZ(0);
  }

  .hero__image-wrapper {
    position: relative;
    width: min(460px, 90vw);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    /* drop-shadow en wrapper, NO en img (evita conflicto con mask en mobile) */
    filter: drop-shadow(0 20px 48px rgba(180,110,80,0.28));
  }

  .hero__ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1.5px solid;
    opacity: 0.35;
  }

  .hero__ring--outer {
    border-color: var(--gold-400);
    animation: rotate-slow 30s linear infinite;
  }

  .hero__ring--inner {
    inset: 15%;
    border-color: var(--rose-300);
    animation: rotate-slow 20s linear infinite reverse;
    border-style: dashed;
  }

  .hero__product-img {
    width: 88%;
    height: 88%;
    object-fit: contain;
    animation: float 7s ease-in-out infinite;
    z-index: 2;
    position: relative;
    /* Difumina suavemente SOLO las esquinas externas manteniendo el centro 100% solido */
    -webkit-mask-image: radial-gradient(
      ellipse 49% 49% at 50% 50%,
      black 0%,
      black 78%,
      rgba(0, 0, 0, 0.65) 92%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 49% 49% at 50% 50%,
      black 0%,
      black 78%,
      rgba(0, 0, 0, 0.65) 92%,
      transparent 100%
    );
  }

  /* Floating chips */
  .hero__chip {
    position: absolute;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(10px);
    border: 1px solid var(--beige-200);
    border-radius: var(--radius-full);
    padding: 0.45rem 0.9rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-secondary);
    box-shadow: var(--shadow-soft);
    white-space: nowrap;
  }

  .hero__chip--1 {
    top: 12%; left: -5%;
    animation: float 6s ease-in-out infinite 0s;
  }

  .hero__chip--2 {
    top: 5%; right: -3%;
    animation: float 6s ease-in-out infinite 1.5s;
  }

  .hero__chip--3 {
    bottom: 15%; left: -8%;
    animation: float 6s ease-in-out infinite 3s;
  }

  /* Scroll hint */
  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    opacity: 0;
    transition: opacity 0.8s ease, transform 0.8s ease;
    transition-delay: 0.48s;
  }

  .hero.is-loaded .hero__scroll-hint {
    opacity: 0.55;
  }

  .hero__scroll-hint:hover { opacity: 1 !important; }

  .hero__scroll-line {
    width: 1.5px;
    height: 36px;
    background: linear-gradient(to bottom, transparent, var(--gold-400));
    border-radius: 1px;

  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero__inner {
      gap: 2rem;
    }
  }

  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 1.5rem;
    }

    .hero__text { order: 2; }
    .hero__visual { order: 1; }

    .hero__desc { margin-inline: auto; }
    .hero__actions { justify-content: center; }
    .hero__badges { justify-content: center; }
    .hero__price-badge { margin-inline: auto; }

    .hero__image-wrapper {
      width: min(340px, 80vw);
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-top: 70px;
    }

    .hero__title {
      font-size: clamp(1.8rem, 8vw, 2.6rem);
    }

    .hero__image-wrapper {
      width: min(280px, 75vw);
    }

    .hero__chip {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .hero__actions a {
      width: 100%;
      justify-content: center;
    }
  }

  /* Seguridad: en mobile, si las animaciones no disparan bien,
     el contenido debe ser visible de todas formas */
  @media (max-width: 900px) {
    .hero__text > *,
    .hero__visual {
      opacity: 1 !important;
      transform: none !important;
    }

    /* Previene pantalla en blanco en scroll mobile */
    .hero {
      min-height: auto;
      padding-block: 3.5rem 2rem;
      padding-top: 90px;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding-top: 80px;
      padding-bottom: 2rem;
    }
  }
</style>

<script>
  // Robust trigger for the entrance transitions
  const triggerLoad = () => {
    const hero = document.getElementById('inicio');
    if (hero) {
      hero.classList.add('is-loaded');
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', triggerLoad);
  } else {
    triggerLoad();
  }

  // Backup fallback
  setTimeout(triggerLoad, 150);
</script>

