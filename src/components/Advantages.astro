---
const advantages = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    title: 'Elaboración artesanal',
    desc: 'Proceso 100% manual en cada pieza. Ninguna vela es idéntica a otra.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Materiales ecológicos',
    desc: 'Cera de soya, colorantes naturales, pabilos de algodón. Sostenible de principio a fin.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>`,
    title: 'Presentación en kit',
    desc: 'Sets y colecciones pensados para regalar o para uso personal. Presentación elegante y cuidada.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
    title: 'Aromas terapéuticos',
    desc: 'Fragancias pensadas para el bienestar. Relajan, energizan o invitan a la meditación.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3a2 2 0 0 0-2 2"/><path d="M19 3a2 2 0 0 1 2 2"/><path d="M21 19a2 2 0 0 1-2 2"/><path d="M5 21a2 2 0 0 1-2-2"/><path d="M9 3h1"/><path d="M9 21h1"/><path d="M14 3h1"/><path d="M14 21h1"/><path d="M3 9v1"/><path d="M21 9v1"/><path d="M3 14v1"/><path d="M21 14v1"/></svg>`,
    title: 'Diseño elegante y reutilizable',
    desc: 'Frascos de vidrio que se convierten en objetos decorativos cuando se termina la vela.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: 'Experiencia de bienestar',
    desc: 'Más que un producto: un ritual de autocuidado, relajación y conexión contigo mismo.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: 'Atención personalizada',
    desc: 'Trato directo con la creadora. Pedidos a la medida para eventos, empresas y regalos corporativos.',
  },
];

const useCases = [
  { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, label: 'Decoración del hogar' },
  { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`, label: 'Aromaterapia' },
  { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>`, label: 'Meditación' },
  { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`, label: 'Eventos especiales' },
  { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>`, label: 'Regalos únicos' },
  { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`, label: 'Relajación' },
];
---

<section id="ventajas" class="advantages-section">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Ventajas y Beneficios</span>
      <h2>¿Por qué elegir <span class="gradient-text">Biaani</span>?</h2>
      <p class="section-desc">
        Cada ventaja de nuestras velas está pensada para mejorar tu calidad de vida
        y transformar tus momentos cotidianos en experiencias únicas.
      </p>
    </div>

    <!-- Advantages masonry grid -->
    <div class="advantages-grid">
      {advantages.map((adv, i) => (
        <div
          class={`adv-card animate-on-scroll ${i === 0 ? 'adv-card--featured' : ''}`}
          style={`animation-delay: ${i * 0.07}s`}
        >
          <div class="adv-card__icon" set:html={adv.icon} />
          <div class="adv-card__body">
            <h3>{adv.title}</h3>
            <p>{adv.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Use cases -->
    <div class="use-cases animate-on-scroll">
      <p class="use-cases__label">Úsalas para</p>
      <div class="use-cases__grid">
        {useCases.map(u => (
          <div class="use-case-item">
            <div class="use-case-item__icon" set:html={u.icon} />
            <span>{u.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Stats row -->
    <div class="stats-row animate-on-scroll">
      {[
        { val: '100%', label: 'Natural' },
        { val: '5+', label: 'Aromas únicos' },
        { val: '∞', label: 'Personalización' },
        { val: '♻', label: 'Envase reutilizable' },
      ].map(s => (
        <div class="stat-item">
          <span class="stat-item__val">{s.val}</span>
          <span class="stat-item__label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .advantages-section {
    padding: 6rem 0;
    background: var(--off-white);
    position: relative;
    overflow: hidden;
  }

  .advantages-section::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--beige-200), transparent);
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-header h2 { margin-bottom: 1rem; }
  .section-desc {
    color: var(--text-secondary);
    max-width: 560px;
    margin-inline: auto;
    line-height: 1.7;
  }

  /* Advantages grid */
  .advantages-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .adv-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    background: var(--white);
    border: 1px solid var(--beige-100);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .adv-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--rose-300), var(--gold-400));
    opacity: 0;
    transition: opacity 0.35s;
  }

  .adv-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-card);
    border-color: var(--rose-100);
  }

  .adv-card:hover::after { opacity: 1; }

  .adv-card--featured {
    grid-column: span 2;
    flex-direction: row;
    align-items: flex-start;
    background: linear-gradient(145deg, var(--rose-50), var(--white));
    border-color: var(--rose-200);
  }

  .adv-card__icon {
    width: 54px;
    height: 54px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--rose-50), var(--beige-100));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold-500);
    flex-shrink: 0;
    transition: var(--transition);
  }

  .adv-card:hover .adv-card__icon {
    background: linear-gradient(135deg, var(--rose-100), var(--beige-200));
  }

  .adv-card__body h3 {
    font-size: 1rem;
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
  }

  .adv-card__body p {
    font-size: 0.86rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Use cases */
  .use-cases {
    background: linear-gradient(135deg, var(--beige-50), var(--rose-50));
    border: 1px solid var(--beige-200);
    border-radius: var(--radius-xl);
    padding: 2rem 2.5rem;
    margin-bottom: 2.5rem;
  }

  .use-cases__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold-500);
    margin-bottom: 1.25rem;
  }

  .use-cases__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1rem;
  }

  .use-case-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    text-align: center;
    background: var(--white);
    border: 1px solid var(--beige-100);
    border-radius: var(--radius-md);
    padding: 1rem 0.75rem;
    transition: var(--transition);
    cursor: default;
  }

  .use-case-item:hover {
    border-color: var(--rose-200);
    box-shadow: var(--shadow-soft);
    transform: translateY(-3px);
  }

  .use-case-item__icon {
    color: var(--rose-400);
  }

  .use-case-item span {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  /* Stats */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .stat-item {
    text-align: center;
    background: var(--white);
    border: 1px solid var(--beige-100);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1rem;
    transition: var(--transition);
  }

  .stat-item:hover {
    border-color: var(--rose-200);
    box-shadow: var(--shadow-soft);
  }

  .stat-item__val {
    display: block;
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 400;
    background: linear-gradient(135deg, var(--gold-500), var(--rose-400));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.4rem;
    line-height: 1;
  }

  .stat-item__label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  @media (max-width: 1100px) {
    .advantages-grid { grid-template-columns: repeat(2, 1fr); }
    .adv-card--featured { grid-column: span 1; flex-direction: column; }
    .use-cases__grid { grid-template-columns: repeat(3, 1fr); }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .advantages-section { padding: 4rem 0; }
    .advantages-grid { grid-template-columns: 1fr; }
    .use-cases__grid { grid-template-columns: repeat(2, 1fr); }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
    .use-cases { padding: 1.5rem; }
  }

  @media (max-width: 400px) {
    .use-cases__grid { grid-template-columns: 1fr 1fr; }
    .stats-row { grid-template-columns: 1fr 1fr; }
  }
</style>
