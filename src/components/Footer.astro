<style>
  .footer {
    background: linear-gradient(160deg, var(--text-primary) 0%, #1a0f0f 100%);
    color: var(--beige-200);
  }

  .footer__top {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .footer__top-inner {
    display: grid;
    grid-template-columns: auto 1fr 1fr auto;
    gap: 3rem;
    align-items: start;
  }

  /* Brand */
  .footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
  }

  .footer__brand img {
    width: 70px;
    height: 70px;
    object-fit: contain;
    border-radius: 50%;
    /* Invierte el blend para fondos oscuros */
    mix-blend-mode: screen;
    filter: brightness(1.1);
    transition: transform 0.3s;
  }

  .footer__brand img:hover {
    transform: rotate(-5deg) scale(1.06);
  }

  .footer__brand-name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    color: var(--white);
  }

  .footer__brand-sub {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--beige-300);
    opacity: 0.7;
  }

  /* Nav */
  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__nav-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 0.25rem;
  }

  .footer__nav a {
    font-size: 0.88rem;
    color: var(--beige-200);
    opacity: 0.75;
    transition: opacity 0.2s, color 0.2s;
  }

  .footer__nav a:hover {
    opacity: 1;
    color: var(--rose-200);
  }

  /* Contact */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.84rem;
    color: var(--beige-200);
    opacity: 0.75;
    transition: opacity 0.2s, color 0.2s;
    line-height: 1.4;
  }

  a.footer__contact-item:hover {
    opacity: 1;
    color: var(--rose-200);
  }

  .footer__contact-item svg {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .footer__contact-item--addr { cursor: default; }

  /* Tagline */
  .footer__tagline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 220px;
  }

  .footer__quote {
    font-size: 1.1rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--beige-300);
    border-left: 2px solid var(--gold-400);
    padding-left: 1rem;
  }

  .footer__wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: linear-gradient(135deg, #25D366, #128C7E);
    color: var(--white);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    transition: var(--transition);
    width: fit-content;
  }

  .footer__wa-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37,211,102,0.3);
  }

  /* Bottom bar */
  .footer__bottom {
    padding: 1.25rem 0;
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer__bottom p {
    font-size: 0.78rem;
    color: var(--beige-200);
    opacity: 0.5;
  }

  .footer__bottom-right {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  @media (max-width: 1000px) {
    .footer__top-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer__brand {
      align-items: flex-start;
      text-align: left;
    }
  }

  @media (max-width: 600px) {
    .footer__top-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer__tagline {
      max-width: 100%;
    }

    .footer__top {
      padding: 3rem 0 2rem;
    }
  }

  @media (max-width: 380px) {
    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
